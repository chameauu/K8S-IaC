# Prometheus Stack Helm Values
# Generated by Ansible - Do not edit manually

prometheus:
  prometheusSpec:
    retention: {{ prometheus_retention }}
    replicas: {{ prometheus_replicas }}
    
    # Storage configuration - disabled for simplicity
    # storageSpec:
    #   volumeClaimTemplate:
    #     spec:
    #       storageClassName: {{ prometheus_storage_class }}
    #       accessModes: ["ReadWriteOnce"]
    #       resources:
    #         requests:
    #           storage: {{ prometheus_storage_size }}
    
    # Enable pod annotation scraping
    podMonitorSelectorNilUsesHelmValues: false
    serviceMonitorSelectorNilUsesHelmValues: false
    
    # Scrape config for pod annotations
    additionalScrapeConfigs:
      - job_name: 'kubernetes-pods'
        kubernetes_sd_configs:
          - role: pod
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_scrape]
            action: keep
            regex: true
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_path]
            action: replace
            target_label: __metrics_path__
            regex: (.+)
          - source_labels: [__address__, __meta_kubernetes_pod_annotation_prometheus_io_port]
            action: replace
            regex: ([^:]+)(?::\d+)?;(\d+)
            replacement: $1:$2
            target_label: __address__
          - action: labelmap
            regex: __meta_kubernetes_pod_label_(.+)
          - source_labels: [__meta_kubernetes_namespace]
            action: replace
            target_label: kubernetes_namespace
          - source_labels: [__meta_kubernetes_pod_name]
            action: replace
            target_label: kubernetes_pod_name

  # Prometheus service configuration
  service:
    type: {{ prometheus_service_type }}
    port: 9090
    nodePort: {{ prometheus_service_port }}

grafana:
  adminPassword: {{ grafana_admin_password }}
  
  # Persistence configuration - disabled for simplicity
  persistence:
    enabled: false
  
  # Service configuration
  service:
    type: {{ grafana_service_type }}
    port: 80
    nodePort: {{ grafana_service_port }}
  
  # Disable default datasources to avoid conflicts
  sidecar:
    datasources:
      enabled: false

alertmanager:
  alertmanagerSpec:
    replicas: 1
    # Storage configuration - disabled for simplicity
    # storage:
    #   volumeClaimTemplate:
    #     spec:
    #       storageClassName: {{ prometheus_storage_class }}
    #       accessModes: ["ReadWriteOnce"]
    #       resources:
    #         requests:
    #           storage: 1Gi
  
  # Service configuration
  service:
    type: {{ prometheus_service_type }}
    port: 9093
    nodePort: {{ alertmanager_service_port }}

# Node exporter for node metrics
prometheus-node-exporter:
  enabled: true

# Kube state metrics for Kubernetes API metrics
kube-state-metrics:
  enabled: true
